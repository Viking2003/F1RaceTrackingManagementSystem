@model IEnumerable<F1RaceTracker.Models.Race>
@{
    ViewData["Title"] = "Races";
    var seasons = ViewBag.Seasons as List<int>;
    var currentSeason = (int)ViewBag.CurrentSeason;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="fas fa-flag-checkered me-2 text-danger"></i> Race Calendar</h1>
    <a asp-action="Create" class="btn btn-f1"><i class="fas fa-plus me-1"></i> Add Race</a>
</div>

<!-- Season Filter -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    @foreach (var s in seasons ?? new List<int>())
    {
        <a asp-action="Index" asp-route-season="@s"
           class="btn btn-sm @(s == currentSeason ? "btn-f1" : "btn-outline-secondary")">@s</a>
    }
</div>

<div class="f1-card">
    <div class="card-header"><i class="fas fa-calendar me-2 text-danger"></i>@currentSeason Season — @Model.Count() Races</div>
    <div class="card-body p-0">
        <table class="table f1-table mb-0">
            <thead>
                <tr>
                    <th>Rnd</th><th>Race</th><th>Circuit</th><th>Country</th><th>Date</th><th>Laps</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var race in Model)
            {
                var statusBadge = race.Status switch {
                    F1RaceTracker.Models.RaceStatus.Completed  => "badge-completed",
                    F1RaceTracker.Models.RaceStatus.Scheduled  => "badge-scheduled",
                    F1RaceTracker.Models.RaceStatus.InProgress => "badge-inprogress",
                    _                                           => "badge-cancelled"
                };
                <tr>
                    <td><span class="badge bg-secondary">@race.Round</span></td>
                    <td>
                        <a asp-action="Details" asp-route-id="@race.Id" class="text-dark fw-semibold text-decoration-none">
                            @race.Name
                        </a>
                    </td>
                    <td class="text-muted small">@race.Circuit</td>
                    <td>@race.Country</td>
                    <td>@race.RaceDate.ToString("dd MMM yyyy")</td>
                    <td>@race.Laps</td>
                    <td><span class="badge @statusBadge">@race.Status</span></td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@race.Id" class="btn btn-sm btn-outline-info" title="View"><i class="fas fa-eye"></i></a>
                            <a asp-action="Edit" asp-route-id="@race.Id" class="btn btn-sm btn-outline-warning" title="Edit"><i class="fas fa-edit"></i></a>
                            <form asp-action="Delete" asp-route-id="@race.Id" method="post" onsubmit="return confirm('Delete this race?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
