@model F1RaceTracker.Models.Race
@{
    ViewData["Title"] = "Edit Race";
}

<div class="page-header">
    <a asp-action="Index" class="text-muted text-decoration-none small"><i class="fas fa-arrow-left me-1"></i> Back</a>
    <h1 class="mt-1"><i class="fas fa-edit me-2 text-warning"></i> Edit Race</h1>
</div>

<div class="row justify-content-center">
<div class="col-lg-8">
<div class="f1-card">
<div class="card-body p-4">
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Race Name *</label>
            <input asp-for="Name" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Season *</label>
            <input asp-for="Season" class="form-control" type="number" required />
        </div>
        <div class="col-md-8">
            <label class="form-label">Circuit *</label>
            <input asp-for="Circuit" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Round #</label>
            <input asp-for="Round" class="form-control" type="number" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Country</label>
            <input asp-for="Country" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">City</label>
            <input asp-for="City" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Race Date</label>
            <input asp-for="RaceDate" class="form-control" type="date" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Laps</label>
            <input asp-for="Laps" class="form-control" type="number" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Circuit Length</label>
            <input asp-for="CircuitLength" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                <option value="0">Scheduled</option>
                <option value="1">In Progress</option>
                <option value="2">Completed</option>
                <option value="3">Cancelled</option>
            </select>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-f1"><i class="fas fa-save me-1"></i> Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
</div>
</div>
</div>
</div>
