@model IEnumerable<F1RaceTracker.Models.Team>
@{
    ViewData["Title"] = "Teams";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="fas fa-users me-2 text-danger"></i> Teams</h1>
    <a asp-action="Create" class="btn btn-f1"><i class="fas fa-plus me-1"></i> Add Team</a>
</div>

<div class="row g-3">
@foreach (var t in Model)
{
    <div class="col-md-6 col-lg-4">
        <div class="f1-card h-100" style="border-top: 4px solid @t.ColorHex">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded me-3 d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:@t.ColorHex;color:#fff;font-weight:900;font-size:1.1rem">
                        @t.Name[0]
                    </div>
                    <div>
                        <h5 class="text-white mb-0 fw-bold">@t.Name</h5>
                        <small class="text-muted">@t.Country &bull; Est. @t.FoundedYear</small>
                    </div>
                </div>
                <div class="d-flex gap-3 mb-3">
                    <div>
                        <div class="text-warning fw-bold">@t.Championships</div>
                        <div class="text-muted" style="font-size:0.7rem">TITLES</div>
                    </div>
                    <div>
                        <div class="text-white fw-bold">@t.Drivers.Count</div>
                        <div class="text-muted" style="font-size:0.7rem">DRIVERS</div>
                    </div>
                </div>
                <div class="text-muted small mb-1"><i class="fas fa-car me-1"></i> @t.CarName</div>
                <div class="text-muted small mb-3"><i class="fas fa-user-tie me-1"></i> @t.PrincipalName</div>
                <div class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-info flex-fill">Details</a>
                    <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                    <form asp-action="Delete" asp-route-id="@t.Id" method="post" onsubmit="return confirm('Delete @t.Name?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
</div>
