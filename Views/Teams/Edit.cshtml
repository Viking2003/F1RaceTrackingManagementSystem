@model F1RaceTracker.Models.Team
@{
    ViewData["Title"] = "Edit Team";
}

<div class="page-header">
    <a asp-action="Index" class="text-muted text-decoration-none small"><i class="fas fa-arrow-left me-1"></i> Back</a>
    <h1 class="mt-1"><i class="fas fa-edit me-2 text-warning"></i> Edit Team</h1>
</div>

<div class="row justify-content-center">
<div class="col-lg-7">
<div class="f1-card">
<div class="card-body p-4">
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Team Name *</label>
            <input asp-for="Name" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Country</label>
            <input asp-for="Country" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Team Principal</label>
            <input asp-for="PrincipalName" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Car Name</label>
            <input asp-for="CarName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Founded Year</label>
            <input asp-for="FoundedYear" class="form-control" type="number" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Championships</label>
            <input asp-for="Championships" class="form-control" type="number" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Team Color</label>
            <input asp-for="ColorHex" class="form-control" type="color" />
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-f1"><i class="fas fa-save me-1"></i> Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
</div>
</div>
</div>
</div>
