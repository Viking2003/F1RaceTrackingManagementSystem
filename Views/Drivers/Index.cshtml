@model IEnumerable<F1RaceTracker.Models.Driver>
@{
    ViewData["Title"] = "Drivers";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1><i class="fas fa-helmet-safety me-2 text-danger"></i> Drivers</h1>
    <a asp-action="Create" class="btn btn-f1"><i class="fas fa-plus me-1"></i> Add Driver</a>
</div>

<div class="row g-3">
@foreach (var d in Model)
{
    <div class="col-md-6 col-lg-4">
        <div class="f1-card h-100" style="border-left: 3px solid @(d.Team?.ColorHex ?? "#555")">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <span class="driver-num mb-2 d-inline-block">@d.DriverNumber</span>
                        <h5 class="text-white mb-0 fw-bold">@d.FullName</h5>
                        <small class="text-muted">@d.Nationality &bull; @d.Code</small>
                    </div>
                    @if (d.Championships > 0)
                    {
                        <span title="@d.Championships x World Champion" class="text-warning">
                            @for (int i = 0; i < Math.Min(d.Championships, 4); i++) { <text>🏆</text> }
                        </span>
                    }
                </div>
                @if (d.Team != null)
                {
                    <div class="mb-3">
                        <span class="team-strip" style="background:@d.Team.ColorHex"></span>
                        <span class="text-muted small">@d.Team.Name</span>
                    </div>
                }
                <div class="d-flex gap-3 mb-3">
                    <div class="text-center">
                        <div class="text-danger fw-bold">@d.TotalWins</div>
                        <div class="text-muted" style="font-size:0.7rem">WINS</div>
                    </div>
                    <div class="text-center">
                        <div class="text-warning fw-bold">@d.TotalPodiums</div>
                        <div class="text-muted" style="font-size:0.7rem">PODIUMS</div>
                    </div>
                    <div class="text-center">
                        <div class="text-info fw-bold">@d.Championships</div>
                        <div class="text-muted" style="font-size:0.7rem">TITLES</div>
                    </div>
                </div>
                <div class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-outline-info flex-fill">Profile</a>
                    <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-outline-warning"><i class="fas fa-edit"></i></a>
                    <form asp-action="Delete" asp-route-id="@d.Id" method="post" onsubmit="return confirm('Delete @d.FullName?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
</div>
